# ===== Frontend / Deploy =====
SITE_BASE_URL=https://anime.example.com
SITE_TAGLINE=Streaming anime static + HLS + Cloudflare R2
DATA_BASE_URL=/data
MEDIA_BASE_URL=/media
CDN_BASE_URL=https://cdn.example.com

# ===== Cloudflare Pages =====
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT=anime-stream

# ===== Cloudflare Zone (purge cache) =====
CLOUDFLARE_ZONE_ID=

# ===== Cloudflare R2 =====
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=anime-stream
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://cdn.example.com
